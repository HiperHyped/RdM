{
  "version": "ai-rules-v2",
  "schema_version": "declarative-formulas-v1",
  "description": "Catalogo estrutural das regras da IA V2. Este arquivo separa sinais, formulas declarativas, pesos e limiares da implementacao em JavaScript, mantendo todos os parametros ligados aos quatro grupos do perfil: negociacao, visao, personalidade e habilidades.",
  "normalization": {
    "range": "0..1",
    "planning_horizon_turns": {
      "stored_range": "0..1",
      "runtime_turns": "0..20"
    },
    "skill_noise": {
      "source": "profile.skill.evaluation_noise",
      "interpretation": "0 significa leitura estavel; 1 significa ruido maximo permitido pela regra local"
    }
  },
  "formula_conventions": {
    "principle": "Nenhuma formula numerica deve depender de strings avaliadas. Toda conta precisa estar decomposta em estrutura declarativa com pesos editaveis.",
    "operators": [
      "weighted_sum",
      "weighted_sum_with_base",
      "weighted_sum_with_noise",
      "weighted_sum_with_context",
      "normalized_ratio",
      "price_multiplier",
      "asset_kind_lookup"
    ]
  },
  "signal_catalog": {
    "buy_openness": {
      "source": "profile.negotiation.buy_openness",
      "group": "negotiation",
      "description": "Agressividade para entrar em compras e perseguir ativos de terceiros."
    },
    "sell_openness": {
      "source": "profile.negotiation.sell_openness",
