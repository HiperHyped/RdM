      "description": "Indicador contextual de sobra de caixa frente a mesa."
    },
    "late_game": {
      "description": "Indicador contextual de fase tardia da partida."
    },
    "seller_lock": {
      "description": "Resistencia percebida do vendedor no contexto atual."
    },
    "buyer_attachment": {
      "description": "Apego do comprador a manter liquidez e patrimonio atuais."
    },
    "interest_score": {
      "description": "Score de interesse ja consolidado para a negociacao."
    },
    "base_price": {
      "description": "Preco base do ativo usado como ancora de negociacao."
    }
  },
  "derived_signals": {
    "asset_focus": {
      "type": "asset_kind_lookup",
      "description": "Converte o tipo do ativo no peso estrategico principal do perfil.",
      "mapping": {
        "port": {
          "signal": "focus_port"
        },
        "permission": {
          "signal": "focus_permission"
        },
        "toll": {
          "signal": "focus_toll"
        },
        "other": {
          "constant": 0.5
        }
      }
    },
    "origin_synergy": {
      "type": "weighted_sum",
      "description": "Mede o quanto o ativo reforca origem, porto proprio e ganho associado ao bonus de origem.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "focus_origin_bonus",
          "weight": 0.5
        },
        {
          "signal": "focus_port",
          "weight": 0.3
        },
        {
          "signal": "origin_control_gain_norm",
          "source": "runtime_context",
          "weight": 0.2
        }
      ]
    },
    "monopoly_progress": {
      "type": "weighted_sum",
      "description": "Mede quanto a acao aproxima o fechamento ou a preservacao de um conjunto regional.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "focus_monopoly",
          "weight": 0.55
        },
        {
          "signal": "region_completion_after_action_norm",
          "source": "runtime_context",
          "weight": 0.3
        },
        {
          "signal": "combo_awareness",
          "weight": 0.15
        }
      ]
    },
    "permission_synergy": {
      "type": "weighted_sum",
      "description": "Mede o ganho de rede e de contratos destravados por uma permissao ou ativo conectado a ela.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "focus_permission",
          "weight": 0.5
        },
        {
          "signal": "route_unlock_gain_norm",
          "source": "runtime_context",
          "weight": 0.25
        },
        {
          "signal": "combo_awareness",
          "weight": 0.25
        }
      ]
    },
    "yield_projection": {
      "type": "weighted_sum",
      "description": "Projeta retorno economico do ativo no horizonte relevante.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "projected_income_norm",
          "source": "runtime_context",
          "weight": 0.45
        },
        {
          "signal": "planning_horizon",
          "weight": 0.3
        },
        {
          "signal": "foresight",
          "weight": 0.25
        }
      ]
    },
    "cash_headroom": {
      "type": "normalized_ratio",
      "description": "Mede folga de caixa apos uma acao em relacao a reserva alvo.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "numerator": {
        "type": "weighted_sum",
        "terms": [
          {
            "signal": "cash_after_action",
            "source": "runtime_context",
            "weight": 1.0
          },
          {
            "signal": "reserve_cash_target_amount",
            "source": "runtime_context",
            "weight": -1.0
          }
        ]
      },
      "denominator": {
        "type": "max",
        "candidates": [
          {
            "signal": "action_cost",
            "source": "runtime_context"
          },
          {
            "constant": 1
          }
        ]
      }
    },
    "cash_pressure": {
      "type": "normalized_ratio",
      "description": "Mede o aperto de caixa atual frente a necessidade imediata e reserva desejada.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "numerator": {
        "type": "weighted_sum",
        "terms": [
          {
            "signal": "reserve_cash_target_amount",
            "source": "runtime_context",
            "weight": 1.0
          },
          {
            "signal": "current_cash",
            "source": "runtime_context",
            "weight": -1.0
          }
        ]
      },
      "denominator": {
        "type": "max",
        "candidates": [
          {
            "signal": "reserve_cash_target_amount",
            "source": "runtime_context"
          },
          {
            "constant": 1
          }
        ]
      }
    },
    "permission_need": {
      "type": "weighted_sum",
      "description": "Mede urgencia de adquirir permissao extra para sustentar expansao operacional.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "open_contract_slots_pressure",
          "source": "runtime_context",
          "weight": 0.55
        },
        {
          "signal": "focus_permission",
          "weight": 0.25
        },
        {
          "signal": "planning_horizon",
          "weight": 0.1
        },
        {
          "signal": "combo_awareness",
          "weight": 0.1
        }
      ]
    },
    "network_synergy": {
      "type": "weighted_sum",
      "description": "Mede quanto a acao expande cobertura e flexibilidade de malha.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "route_unlock_gain_norm",
          "source": "runtime_context",
          "weight": 0.4
        },
        {
          "signal": "focus_permission",
          "weight": 0.35
        },
        {
          "signal": "focus_origin_bonus",
          "weight": 0.25
        }
      ]
    },
    "coverage_gain": {
      "type": "weighted_sum",
      "description": "Mede crescimento de cobertura geografica e de destinos uteis.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "reachable_destinations_gain_norm",
          "source": "runtime_context",
          "weight": 0.6
        },
        {
          "signal": "route_unlock_gain_norm",
          "source": "runtime_context",
          "weight": 0.4
        }
      ]
    },
    "contract_synergy": {
      "type": "weighted_sum",
      "description": "Mede melhora esperada na carteira de contratos pela nova permissao.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "contract_value_gain_norm",
          "source": "runtime_context",
          "weight": 0.55
        },
        {
          "signal": "combo_awareness",
          "weight": 0.45
        }
      ]
    },
    "strategic_value": {
      "type": "weighted_sum",
      "description": "Mede valor estrutural do ativo para o vendedor atual.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "asset_focus",
          "weight": 0.4
        },
        {
          "signal": "monopoly_progress",
          "weight": 0.3
        },
        {
          "signal": "origin_synergy",
          "weight": 0.15
        },
        {
          "signal": "combo_awareness",
          "weight": 0.15
        }
      ]
    },
    "combo_penalty": {
      "type": "weighted_product",
      "description": "Penalidade por desmontar sinergia ao hipotecar ou vender um ativo.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "factors": [
        {
          "signal": "combo_break_loss_norm",
          "source": "runtime_context",
          "weight": 1.0
        },
        {
          "signal": "combo_awareness",
          "weight": 1.0
        }
      ]
    },
    "combo_value": {
      "type": "weighted_product",
      "description": "Valor de sinergia restaurado ao resgatar um ativo.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "factors": [
        {
          "signal": "combo_restore_gain_norm",
          "source": "runtime_context",
          "weight": 1.0
        },
        {
          "signal": "combo_awareness",
          "weight": 1.0
        }
      ]
    },
    "asset_opportunity": {
      "type": "weighted_sum",
      "description": "Mede o tamanho da oportunidade estrutural imediata que um cupom pode acelerar.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "bank_or_market_opportunity_norm",
          "source": "runtime_context",
          "weight": 0.45
        },
        {
          "signal": "network_synergy",
          "weight": 0.3
        },
        {
          "signal": "monopoly_progress",
          "weight": 0.25
        }
      ]
    },
    "turn_value": {
      "type": "weighted_sum",
      "description": "Mede o valor marginal de capturar vantagem nesta rodada em vez de esperar.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "immediate_turn_swing_norm",
          "source": "runtime_context",
          "weight": 0.55
        },
        {
          "signal": "timing_quality",
          "weight": 0.25
        },
        {
          "signal": "risk_tolerance",
          "weight": 0.2
        }
      ]
    },
    "opponent_monopoly_threat": {
      "type": "weighted_sum",
      "description": "Mede o risco de o oponente consolidar um conjunto forte sem intervencao.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "opponent_region_completion_norm",
          "source": "runtime_context",
          "weight": 0.65
        },
        {
          "signal": "opponent_income_swing_norm",
          "source": "runtime_context",
          "weight": 0.35
        }
      ]
    },
    "self_protection": {
      "type": "weighted_sum",
      "description": "Mede ganho defensivo imediato para a propria posicao.",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "terms": [
        {
          "signal": "self_loss_prevention_norm",
          "source": "runtime_context",
          "weight": 0.55
        },
        {
          "signal": "asset_attachment",
          "weight": 0.45
        }
      ]
    }
  },
  "decision_families": {
    "liquidity": {
      "label": "Liquidez",
      "goal": "Manter caixa funcional, evitar colapso e decidir quando hipotecar ou resgatar ativos.",
      "decisions": {
        "reserve_cash_target": {
          "mode": "formula",
          "description": "Define o caixa alvo antes de compras, contraofertas, uso de cupons e resgates.",
          "formula_spec": {
            "type": "weighted_sum_with_context",
            "base": 0.18,
            "terms": [
              {
                "signal": "cash_reserve_ratio",
                "weight": 0.42
              },
              {
                "signal": "liquidity_discipline",
                "weight": 0.18
              },
              {
                "signal": "planning_horizon",
                "weight": 0.12
              },
              {
                "signal": "focus_origin_bonus",
                "weight": 0.06
              },
              {
                "signal": "focus_monopoly",
                "weight": 0.08
              },
              {
                "signal": "risk_tolerance",
                "weight": -0.16,
                "label": "risk_tolerance_relief"
              }
            ],
            "context_adjustments": [
              {
                "signal": "under_threat",
                "source": "runtime_context",
                "weight": 0.16
              },
              {
                "signal": "ahead_on_cash",
                "source": "runtime_context",
                "weight": -0.08
              },
              {
                "signal": "late_game",
                "source": "runtime_context",
                "weight": 0.05
              }
            ],
            "clamp": {
              "min": 0.08,
              "max": 0.72
            }
          }
        },
        "mortgage_candidate": {
          "mode": "rank_then_select",
          "description": "Escolhe o ativo menos estrategico para gerar caixa sob pressao.",
          "ranking_formula": {
            "type": "weighted_sum",
            "select": "highest_score",
            "terms": [
              {
                "signal": "cash_generated",
                "source": "runtime_context",
                "weight": 0.38
              },
              {
                "signal": "asset_focus",
                "weight": -0.22,
                "label": "asset_focus_penalty"
              },
              {
                "signal": "origin_synergy",
                "weight": -0.12,
                "label": "origin_synergy_penalty"
              },
              {
                "signal": "combo_penalty",
                "weight": -0.12
              },
              {
                "signal": "asset_attachment",
                "weight": -0.08,
                "label": "asset_attachment_penalty"
              },
              {
                "signal": "timing_quality",
                "weight": 0.06,
                "label": "timing_quality_bonus"
              },
              {
                "signal": "late_game_keep_penalty",
                "source": "runtime_context",
                "weight": -0.05
              }
            ]
          },
          "thresholds": {
            "must_raise_cash_gap_ratio": 0.12,
            "skip_if_safe_ratio": 0.03
          }
        },
        "redeem_candidate": {
          "mode": "rank_then_select",
          "description": "Escolhe o melhor ativo hipotecado para resgatar quando o caixa excede a reserva alvo.",
          "ranking_formula": {
            "type": "weighted_sum",
            "select": "highest_score",
            "terms": [
              {
                "signal": "asset_focus",
                "weight": 0.28,
                "label": "asset_focus_value"
              },
              {
                "signal": "origin_synergy",
                "weight": 0.14,
                "label": "origin_synergy_value"
              },
              {
                "signal": "combo_value",
                "weight": 0.18
              },
              {
                "signal": "yield_recovery",
                "source": "runtime_context",
                "weight": 0.16
              },
              {
                "signal": "foresight",
                "weight": 0.1,
                "label": "foresight_bonus"
              },
              {
                "signal": "timing_quality",
                "weight": 0.08,
                "label": "timing_quality_bonus"
              },
              {
                "signal": "cash_pressure",
                "weight": -0.2,
                "label": "liquidity_penalty"
              }
            ]
          },
          "thresholds": {
            "redeem": 0.57,
            "stretch_redeem": 0.67
          }
        }
      }
    },
    "acquisition": {
      "label": "Compra e Expansao",
      "goal": "Decidir compras do banco, compra de permissao extra e prioridade entre ativos disponiveis.",
      "decisions": {
        "bank_property_purchase": {
          "mode": "score_vs_threshold",
          "description": "Decide se um ativo do banco vale o investimento no preco atual.",
          "scoring_formula": {
            "type": "weighted_sum_with_noise",
            "terms": [
              {
                "signal": "asset_focus",
                "weight": 0.24
              },
              {
                "signal": "origin_synergy",
                "weight": 0.14
              },
              {
                "signal": "monopoly_progress",
                "weight": 0.14
              },
